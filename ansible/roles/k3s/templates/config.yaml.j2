# Managed by Ansible — do not edit manually
# Source: ansible/roles/k3s/templates/config.yaml.j2
# K3s reads this on startup. CLI flags in INSTALL_K3S_EXEC override these.
write-kubeconfig-mode: "{{ k3s_kubeconfig_mode }}"
# See k3s_node_ip / k3s_flannel_iface in group_vars/all/vars.yml for rationale.
node-ip: "{{ k3s_node_ip }}"
flannel-iface: "{{ k3s_flannel_iface }}"
# Disable the embedded kube-router network-policy controller to avoid the
# post-reboot "failed to start networking ... uninitialized taint" restart loop.
# See k3s_disable_network_policy in group_vars/all/vars.yml for the full rationale.
disable-network-policy: {{ k3s_disable_network_policy | bool | lower }}
{% if k3s_default_runtime %}
# Native k3s flag — sets containerd's default runtime WITHOUT a custom
# config.toml.tmpl (which would clobber the base [cri].cni section and break pod
# networking on reboot). See k3s_default_runtime in group_vars/all/vars.yml.
default-runtime: {{ k3s_default_runtime }}
{% endif %}
disable:
{% for c in k3s_disable_components %}
  - {{ c }}
{% endfor %}
secrets-encryption: true
protect-kernel-defaults: true
kubelet-arg:
{% for a in k3s_kubelet_args %}
  - "{{ a }}"
{% endfor %}
kube-controller-manager-arg:
{% for a in k3s_controller_manager_args %}
  - "{{ a }}"
{% endfor %}
kube-apiserver-arg:
{% for a in k3s_apiserver_args %}
  - "{{ a }}"
{% endfor %}
