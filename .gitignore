# Secrets — never commit
*.secret
*.key
.env
.env.*

# K3s kubeconfig
k3s.yaml

# HF cache
hf-cache/

# OS
.DS_Store
Thumbs.db

# Claude Code
CLAUDE.md
.claude/

# Ansible vault password — never commit
ansible/.vault_pass

# Ansible per-host overrides often hold real LAN IPs / NIC names — never commit.
# Scaffolds with RFC 5737 doc addresses stay tracked via the .example suffix.
ansible/host_vars/*/vars.yml

# Ansible retry files
*.retry

# Temporary rendered templates
/tmp/ansible-*

# Superpowers brainstorming companion (local-only state)
.superpowers/
docs/superpowers/
